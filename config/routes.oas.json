{
  "openapi": "3.1.0",
  "info": {
    "version": "1.0.0",
    "title": "SafeContract Gateway"
  },
  "paths": {
    "/rpc": {
      "post": {
        "operationId": "rpc-forward",
        "x-zuplo-route": {
          "corsPolicy": "none",
          "handler": {
            "module": "$import(@zuplo/runtime)",
            "export": "urlForwardHandler",
            "options": {
              "baseUrl": "http://159.65.192.47.nip.io:8545"
            }
          },
          "policies": {
            "inbound": []
          }
        },
        "summary": "RPC"
      }
    },
    "/scan": {
      "post": {
        "operationId": "backend-scan",
        "x-zuplo-route": {
          "corsPolicy": "none",
          "handler": {
            "module": "$import(@zuplo/runtime)",
            "export": "urlForwardHandler",
            "options": {
              "baseUrl": "http://127.0.0.1:8000"
            }
          },
          "policies": {
            "inbound": []
          }
        },
        "summary": "Backend scan"
      }
    },
    "/": {
      "get": {
        "operationId": "frontend-root",
        "x-zuplo-route": {
          "corsPolicy": "none",
          "handler": {
            "module": "$import(@zuplo/runtime)",
            "export": "urlForwardHandler",
            "options": {
              "baseUrl": "http://159.65.192.47.nip.io:3000"
            }
          },
          "policies": {
            "inbound": []
          }
        },
        "summary": "Frontend"
      }
    },
    "/:path(.*)": {
      "x-zuplo-path": {
        "pathMode": "url-pattern"
      },
      "get": {
        "operationId": "frontend-catchall-get",
        "x-zuplo-route": {
          "corsPolicy": "none",
          "handler": {
            "module": "$import(@zuplo/runtime)",
            "export": "urlForwardHandler",
            "options": {
              "baseUrl": "http://159.65.192.47.nip.io:3000"
            }
          },
          "policies": {
            "inbound": []
          }
        },
        "summary": "Get Front"
      },
      "head": {
        "operationId": "frontend-catchall-head",
        "x-zuplo-route": {
          "corsPolicy": "none",
          "handler": {
            "module": "$import(@zuplo/runtime)",
            "export": "urlForwardHandler",
            "options": {
              "baseUrl": "http://159.65.192.47.nip.io:3000"
            }
          },
          "policies": {
            "inbound": []
          }
        },
        "summary": "Head Front"
      }
    }
  }
}